{
  "Logging": {
    "FilePath": "C:\\IdleTimeWatcher\\logs\\idle-.log"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "Watcher": {
    "MinIntervalSeconds": 2,
    "MaxIntervalSeconds": 10,
    "HideConsoleWindow": true,
    "ShowIdleTime": false
  },
  "Zabbix": {
    "Enabled": true,
    "SenderPath": "C:\\zabbix\\zabbix_sender.exe",
    "ServerAddress": "192.168.101.233",
    "ServerPort": 10051,
    "ItemKey": "idletime"
  },
  "PrometheusRemoteWrite": {
    "Enabled": false,
    "Endpoint": "http://192.168.1.73:9090/api/v1/write",
    "JobLabel": "idle_time_watcher",
    "AdditionalLabels": {
      "environment": "production"
    },
    "TimeoutSeconds": 10,
    "BearerToken": ""
  }
}
